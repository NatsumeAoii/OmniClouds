{
  "name": "omnicloud",
  "version": "1.0.0",
  "description": "Full-stack cloud drive aggregation platform that presents multiple storage providers through a single unified workspace.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "npm-run-all --parallel dev:api dev:web",
    "build": "npm run build:web",
    "build:web": "npm --prefix frontend run build",
    "dev:web": "npm --prefix frontend run dev -- --host",
    "dev:api": "npm --prefix backend run dev",
    "start": "npm --prefix backend start"
  },
  "keywords": [
    "cloud-storage",
    "cloud-aggregation",
    "google-drive",
    "onedrive",
    "dropbox",
    "mega",
    "pcloud",
    "s3",
    "vue",
    "express"
  ],
  "author": "OmniCloud contributors",
  "license": "MIT",
  "type": "module",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@vitest/eslint-plugin": "^1.1.44",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "vitest": "^2.1.8"
  }
}
